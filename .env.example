# Kopieer dit bestand naar .env.local en vul de waarden in
# Zet deze ook in als Environment Variables op Vercel

# Google Sheets ID (uit de URL van je spreadsheet)
# Voorbeeld: https://docs.google.com/spreadsheets/d/HIER_STAAT_HET_ID/edit
REACT_APP_SHEET_ID=jouw_sheet_id_hier

# Google API key (aanmaken in Google Cloud Console, alleen Sheets API)
REACT_APP_GOOGLE_API_KEY=jouw_api_key_hier

# URL van je Google Apps Script Web App (na deployen)
REACT_APP_SCRIPT_URL=https://script.google.com/macros/s/JOUW_SCRIPT_ID/exec

# Beheerderswachtwoord voor Ricardo (/beheer pagina)
REACT_APP_BEHEER_TOKEN=kies_een_sterk_wachtwoord
